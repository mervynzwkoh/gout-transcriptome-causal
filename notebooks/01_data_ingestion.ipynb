        "import os\n",
        "\n",
        "# Create the folders we planned [cite: 90]\n",
        "folders = ['data', 'notebooks', 'src', 'docs']\n",
        "for folder in folders:\n",
        "    os.makedirs(folder, exist_ok=True)\n",
        "    # Create a dummy file in each so Git notices the folder\n",
        "    with open(f\"{folder}/.gitkeep\", \"w\") as f:\n",
        "        pass\n",
        "\n",
        "# The \"Big Three\" Git Commands:\n",
        "!git add .\n",
        "!git commit -m \"Initial commit: Established project folder structure\"\n",
